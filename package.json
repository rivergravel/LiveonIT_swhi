{
  "name": "liveonit",
  "version": "1.0.0",
  "description": "LiveonIT - Address search and map",
  "main": "backend/server.js",
  "scripts": {
    "build": "./build.sh",
    "local": "ts-node backend/src/local.ts",
    "local:users": "PATH_OVERRIDE=/users ts-node backend/src/local.ts",
    "local:search": "PATH_OVERRIDE=/api/search QUERY='{\"q\":\"melbourne\"}' ts-node backend/src/local.ts",
    "local:post": "METHOD=POST PATH_OVERRIDE=/users BODY='{\"email\":\"test@test.com\"}' ts-node backend/src/local.ts"
  },
  "dependencies": {
    "axios": "1.14.0",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "ts-node": "^10.9.2"
  }
}
